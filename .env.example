# Google Cloud / Firebase
GOOGLE_CLOUD_PROJECT=ferrous-layout-382117
FIRESTORE_DATABASE_ID=ai-studio-724f6025-f227-47f5-978b-3fcd3f2803d3

# Lokalt: pek på din service account JSON (ikke nødvendig i Cloud Run)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Scanner-innstillinger
MAX_PRICE=50000
PRIMARY_REGIONS=nordland
EXTRA_REGIONS=
UNDERPRICED_THRESHOLD=0.20
MIN_UNDERPRICED_SAVING=5000
TRANSPORT_CHECK=true
TRANSPORT_MIN_SAVING=3000
EXCLUDE_TITLE_SUBSTRINGS=auksjonen.no,auksjon

# Cron-schedule (standard: hvert 6. time)
CRON_SCHEDULE=0 */6 * * *

# Valgfri sikkerhet: Cloud Scheduler sender denne headeren
# SCAN_SECRET=velg-et-hemmelig-passord

# Lokal Chrome-sti (kun lokalt på Windows)
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Sett til 'false' for å deaktivere innebygd cron (bruk kun Cloud Scheduler)
# LOCAL_CRON=false
